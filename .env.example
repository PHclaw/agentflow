# ============================================
# AgentFlow 环境配置示例
# 复制此文件为 .env 并填入实际值
# cp .env.example .env
# ============================================

# --- 数据库 ---
# PostgreSQL（推荐生产使用）
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/agentflow
# SQLite（开发备用，不填则自动使用）
DATABASE_URL=

# --- Redis（可选，用于缓存和会话管理） ---
# REDIS_URL=redis://localhost:6379/0

# --- JWT 认证 ---
# 生产环境请使用强随机密钥：openssl rand -hex 32
JWT_SECRET_KEY=change-me-to-a-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# --- LLM API Keys ---
# 至少需要配置一个 LLM 提供商
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=

# --- 应用配置 ---
APP_NAME=AgentFlow
APP_DEBUG=true
APP_URL=http://localhost:8000

# --- CORS（允许的前端地址，逗号分隔） ---
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# --- Stripe 支付（可选） ---
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
