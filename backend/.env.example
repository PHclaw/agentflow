# AgentFlow 环境变量示例
# 复制此文件为 .env 并填写实际值

# ===== 应用基础 =====
APP_NAME=AgentFlow
DEBUG=true
LOG_LEVEL=INFO

# ===== 数据库 =====
# SQLite (开发)
DATABASE_URL=sqlite+aiosqlite:///./agentflow.db
# PostgreSQL (生产)
# DATABASE_URL=postgresql+asyncpg://agentflow:password@localhost:5432/agentflow

# ===== Redis =====
REDIS_URL=redis://localhost:6379/0

# ===== JWT =====
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# ===== LLM (至少填写一个) =====
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-haiku-20240307
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ===== Embedding =====
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ===== CORS =====
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ===== 文件上传 =====
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=52428800

# ===== 订阅限制 =====
FREE_AGENTS=1
FREE_MESSAGES=100
PRO_AGENTS=5
PRO_MESSAGES=5000

# ===== Stripe (可选) =====
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_PRO=
# STRIPE_PRICE_TEAM=

# ===== agent-* 生态 (可选，未安装时自动回退) =====
# AGENT_CONFIG_ENV=development
# OBSERVABILITY_ENABLED=true
